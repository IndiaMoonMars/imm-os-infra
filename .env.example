# ── IMM-OS Infrastructure — Environment Variables Template ───────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme

# ── InfluxDB ─────────────────────────────────────────────────────
INFLUX_USER=admin
INFLUX_PASSWORD=changeme123
INFLUX_TOKEN=your-super-secret-influx-token-here

# ── Mosquitto (MQTT) ─────────────────────────────────────────────
MOSQUITTO_USER=admin
MOSQUITTO_PASSWORD=changeme

# ── Kafka ────────────────────────────────────────────────────────
KAFKA_USER=admin
KAFKA_PASSWORD=changeme

# ── Keycloak (Auth) ──────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
